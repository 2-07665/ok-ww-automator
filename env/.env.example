# Copy this file to env/.env or set ENV_FILE to point at another env file.
# Process environment values override this file.

# Game
# Path to Wuthering Waves.exe. Required only before launching the game.
GAME_EXE_PATH=D:\Games\Wuthering Waves\Wuthering Waves Game\Wuthering Waves.exe

# Assumed time when the daily task will run, in UTC+08.
# Used for stamina prediction and burn decisions.
DAILY_HOUR=5
DAILY_MINUTE=0

# Google Sheets
# Required for live Sheets reads/writes.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Worksheet names
SHEET_NAME_CONFIG=Config
SHEET_NAME_DAILY=DailyRuns
SHEET_NAME_STAMINA=StaminaRuns
SHEET_NAME_FASTFARM=5to1

# Waves API
WAVES_API_ENABLED=false
WAVES_ROLE_ID=
WAVES_TOKEN=
WAVES_DID=

# Retry
RETRY_MAX_ATTEMPTS=2
RETRY_DELAY_SECONDS=30

# Notices
NOTICE_ENABLED=false
# Comma-separated channels: mailgun, wxpusher
NOTICE_CHANNEL=
# Optional display label for multi-account notices, such as global or cn.
NOTICE_ACCOUNT_ID=
# Do not send post-run notices when the final task result is success.
NOTICE_SKIP_SUCCESS=false

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_RECIPIENT=

# WxPusher simple-push
WXPUSHER_SPT=

# Healthchecks.io
# Requires UUID checks for both scheduled task types.
HEALTHCHECKS_ENABLED=false
HEALTHCHECKS_DAILY_UUID=
HEALTHCHECKS_STAMINA_UUID=

# Scheduler
# This file is a runnable account env if copied to env/*.env.
# Windows Task Scheduler should launch the scheduler module, not set ENV_FILE.
